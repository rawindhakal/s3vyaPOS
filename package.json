{
  "name": "s3vyapos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @s3vya/api db:generate",
    "db:migrate": "pnpm --filter @s3vya/api db:migrate",
    "db:seed": "pnpm --filter @s3vya/api db:seed",
    "db:push": "pnpm --filter @s3vya/api db:push"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.6.3"
  }
}
