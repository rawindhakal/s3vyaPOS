// s3vyaPOS — multi-tenant POS + double-entry accounting
// Every business table carries shopId for tenant isolation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
  ACCOUNTANT
  WAITER
}

enum OrderLogAction {
  CREATED
  ITEMS_UPDATED
  SENT_KOT
  CANCELLED
  SETTLED
}

enum BusinessType {
  RESTAURANT
}

enum StationType {
  KITCHEN
  BAR
}

enum Plan {
  FREE
  STANDARD
  PRO
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalSource {
  MANUAL
  SALE
  PURCHASE
  PAYMENT
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  BANK
  QR
  CREDIT
  GIFT_CARD
  STORE_CREDIT
}

enum GiftCardStatus {
  ACTIVE
  USED
  EXPIRED
  CANCELLED
}

enum PaymentProvider {
  NONE
  ESEWA
  FONEPAY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  COUNTER
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  OPEN
  SETTLED
  CANCELLED
}

enum PrepStatus {
  PENDING
  READY
}

enum PartyPaymentType {
  VENDOR_PAYMENT
  CUSTOMER_RECEIPT
}

enum ReservationStatus {
  BOOKED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  WASTE
  RECIPE_CONSUME
}

enum NotificationChannel {
  SMS
  EMAIL
  WHATSAPP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  LOGGED
}

// ── Tenancy & auth ────────────────────────────────────────────────────
model Shop {
  id           String       @id @default(uuid())
  name         String
  businessType BusinessType @default(RESTAURANT)
  currency     String       @default("NPR")
  plan         Plan         @default(FREE)
  address      String?
  phone        String?
  taxRate      Decimal      @default(0) @db.Decimal(5, 2)
  serviceChargeRate Decimal @default(0) @db.Decimal(5, 2)
  loyaltyEarnRate   Decimal @default(0) @db.Decimal(5, 2) // points earned per 100 spent
  roundOff          Boolean @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  users            User[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  products         Product[]
  categories       Category[]
  sales            Sale[]
  payments         Payment[]
  vendors          Vendor[]
  customers        Customer[]
  bankAccounts     BankAccount[]
  restaurantTables RestaurantTable[]
  orders           Order[]
  purchases        Purchase[]
  partyPayments    PartyPayment[]
  reservations     Reservation[]
  giftCards        GiftCard[]
  saleReturns      SaleReturn[]
  notifications    Notification[]
  feedback         Feedback[]
}

model Notification {
  id        String              @id @default(uuid())
  shopId    String
  channel   NotificationChannel
  to        String
  subject   String?
  body      String
  status    NotificationStatus  @default(QUEUED)
  error     String?
  createdAt DateTime            @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
}

model Feedback {
  id           String   @id @default(uuid())
  shopId       String
  rating       Int
  comment      String?
  customerName String?
  phone        String?
  saleId       String?
  createdAt    DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
}

model User {
  id           String   @id @default(uuid())
  shopId       String
  email        String
  passwordHash String
  fullName     String
  role         Role     @default(CASHIER)
  active       Boolean  @default(true)
  phone        String?
  refreshHash  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop         Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales        Sale[]
  waiterOrders Order[]

  @@unique([shopId, email])
  @@index([shopId])
}

// ── Accounting ────────────────────────────────────────────────────────
model Account {
  id        String      @id @default(uuid())
  shopId    String
  code      String
  name      String
  type      AccountType
  balance   Decimal     @default(0) @db.Decimal(18, 2)
  isSystem  Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  shop  Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  lines JournalLine[]

  @@unique([shopId, code])
  @@index([shopId, type])
}

model JournalEntry {
  id          String        @id @default(uuid())
  shopId      String
  date        DateTime      @default(now())
  description String
  reference   String?
  source      JournalSource @default(MANUAL)
  createdAt   DateTime      @default(now())

  shop  Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  lines JournalLine[]

  @@index([shopId, date])
}

model JournalLine {
  id        String  @id @default(uuid())
  journalId String
  accountId String
  debit     Decimal @default(0) @db.Decimal(18, 2)
  credit    Decimal @default(0) @db.Decimal(18, 2)

  journal JournalEntry @relation(fields: [journalId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id])

  @@index([journalId])
  @@index([accountId])
}

model BankAccount {
  id            String  @id @default(uuid())
  shopId        String
  name          String
  bankName      String?
  accountNumber String?
  accountId     String? // links to chart-of-accounts Account
  createdAt     DateTime @default(now())

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

// ── Inventory ─────────────────────────────────────────────────────────
model Category {
  id     String @id @default(uuid())
  shopId String
  name   String

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([shopId, name])
}

model Product {
  id            String   @id @default(uuid())
  shopId        String
  sku           String
  barcode       String?
  name          String
  description   String?
  categoryId    String?
  purchasePrice Decimal  @default(0) @db.Decimal(18, 2)
  salePrice     Decimal  @default(0) @db.Decimal(18, 2)
  stock         Decimal  @default(0) @db.Decimal(18, 3)
  taxRate       Decimal  @default(0) @db.Decimal(5, 2)
  unit          String   @default("pcs")
  reorderLevel  Decimal  @default(0) @db.Decimal(18, 3)
  station       StationType @default(KITCHEN)
  hasVariations Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  shop          Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category      Category?          @relation(fields: [categoryId], references: [id])
  saleItems     SaleItem[]
  orderItems    OrderItem[]
  purchaseItems PurchaseItem[]
  recipe        RecipeComponent[]  @relation("MenuItem")
  ingredientOf  RecipeComponent[]  @relation("Ingredient")
  movements     StockMovement[]
  variations    ProductVariation[]

  @@unique([shopId, sku])
  @@unique([shopId, barcode])
  @@index([shopId, name])
}

// Sellable variants of a product, e.g. a whisky in 30ml / 60ml / 1L pours.
model ProductVariation {
  id        String  @id @default(uuid())
  shopId    String
  productId String
  name      String
  salePrice Decimal @db.Decimal(18, 2)
  sku       String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([productId])
}

// Recipe / bill-of-materials: a menu product made of ingredient products.
model RecipeComponent {
  id          String  @id @default(uuid())
  shopId      String
  productId   String  // the menu item
  componentId String  // the ingredient product
  quantity    Decimal @db.Decimal(18, 3)

  product   Product @relation("MenuItem", fields: [productId], references: [id], onDelete: Cascade)
  component Product @relation("Ingredient", fields: [componentId], references: [id])

  @@unique([productId, componentId])
  @@index([shopId])
}

// Append-only stock ledger: + quantity = in, - quantity = out.
model StockMovement {
  id        String            @id @default(uuid())
  shopId    String
  productId String
  type      StockMovementType
  quantity  Decimal           @db.Decimal(18, 3)
  reason    String?
  reference String?
  createdAt DateTime          @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([productId])
}

// ── Parties ───────────────────────────────────────────────────────────
model Vendor {
  id        String   @id @default(uuid())
  shopId    String
  name      String
  phone     String?
  email     String?
  address   String?
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())

  shop      Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  purchases Purchase[]
  payments  PartyPayment[]

  @@index([shopId])
}

model Customer {
  id        String   @id @default(uuid())
  shopId    String
  name      String
  phone     String?
  email     String?
  address   String?
  balance   Decimal  @default(0) @db.Decimal(18, 2)
  loyaltyPoints Decimal @default(0) @db.Decimal(18, 2)
  storeCredit   Decimal @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())

  shop      Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sales     Sale[]
  payments  PartyPayment[]
  giftCards GiftCard[]

  @@index([shopId])
}

// ── Sales / POS ───────────────────────────────────────────────────────
model Sale {
  id         String     @id @default(uuid())
  shopId     String
  invoiceNo  String
  customerId String?
  userId     String?
  subtotal       Decimal    @db.Decimal(18, 2)
  discount       Decimal    @default(0) @db.Decimal(18, 2)
  serviceCharge  Decimal    @default(0) @db.Decimal(18, 2)
  tax            Decimal    @default(0) @db.Decimal(18, 2)
  roundOff       Decimal    @default(0) @db.Decimal(18, 2)
  tip            Decimal    @default(0) @db.Decimal(18, 2)
  total          Decimal    @db.Decimal(18, 2)
  refundedTotal  Decimal    @default(0) @db.Decimal(18, 2)
  cogs           Decimal    @default(0) @db.Decimal(18, 2)
  loyaltyEarned  Decimal    @default(0) @db.Decimal(18, 2)
  loyaltyRedeemed Decimal   @default(0) @db.Decimal(18, 2)
  status     SaleStatus @default(COMPLETED)
  note       String?
  journalId  String?
  createdAt  DateTime   @default(now())

  shop     Shop       @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer?  @relation(fields: [customerId], references: [id])
  user     User?      @relation(fields: [userId], references: [id])
  items    SaleItem[]
  payments Payment[]
  returns  SaleReturn[]

  @@unique([shopId, invoiceNo])
  @@index([shopId, createdAt])
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  productId String
  name        String
  variationId String?
  quantity    Decimal @db.Decimal(18, 3)
  unitPrice   Decimal @db.Decimal(18, 2)
  discount    Decimal @default(0) @db.Decimal(18, 2)
  unitCost    Decimal @default(0) @db.Decimal(18, 2)
  lineTotal   Decimal @db.Decimal(18, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
}

model Payment {
  id          String          @id @default(uuid())
  shopId      String
  saleId      String?
  method      PaymentMethod
  provider    PaymentProvider @default(NONE)
  amount      Decimal         @db.Decimal(18, 2)
  status      PaymentStatus   @default(PAID)
  externalRef String?
  qrPayload   String?
  createdAt   DateTime        @default(now())

  shop Shop  @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sale Sale? @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([saleId])
}

// ── Restaurant (modeled now, UI in M4) ────────────────────────────────
model RestaurantTable {
  id       String      @id @default(uuid())
  shopId   String
  name     String
  area     String?
  seats    Int         @default(4)
  status   TableStatus @default(FREE)

  shop         Shop          @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orders       Order[]
  reservations Reservation[]

  @@unique([shopId, name])
  @@index([shopId])
}

model GiftCard {
  id             String         @id @default(uuid())
  shopId         String
  code           String
  initialBalance Decimal        @db.Decimal(18, 2)
  balance        Decimal        @db.Decimal(18, 2)
  status         GiftCardStatus @default(ACTIVE)
  customerId     String?
  expiresAt      DateTime?
  createdAt      DateTime       @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])

  @@unique([shopId, code])
  @@index([shopId])
}

model SaleReturn {
  id           String   @id @default(uuid())
  shopId       String
  saleId       String
  subtotal     Decimal  @db.Decimal(18, 2)
  tax          Decimal  @default(0) @db.Decimal(18, 2)
  total        Decimal  @db.Decimal(18, 2)
  cogs         Decimal  @default(0) @db.Decimal(18, 2)
  refundMethod PaymentMethod
  journalId    String?
  note         String?
  createdAt    DateTime @default(now())

  shop  Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  sale  Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  items SaleReturnItem[]

  @@index([shopId, createdAt])
}

model SaleReturnItem {
  id        String  @id @default(uuid())
  returnId  String
  productId String
  name      String
  quantity  Decimal @db.Decimal(18, 3)
  unitPrice Decimal @db.Decimal(18, 2)
  unitCost  Decimal @default(0) @db.Decimal(18, 2)
  lineTotal Decimal @db.Decimal(18, 2)

  saleReturn SaleReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

model Reservation {
  id           String            @id @default(uuid())
  shopId       String
  tableId      String?
  customerName String
  phone        String?
  partySize    Int               @default(2)
  reservedAt   DateTime
  status       ReservationStatus @default(BOOKED)
  note         String?
  createdAt    DateTime          @default(now())

  shop  Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  table RestaurantTable? @relation(fields: [tableId], references: [id])

  @@index([shopId, reservedAt])
}

model Order {
  id           String      @id @default(uuid())
  shopId       String
  tableId      String?
  waiterId     String?
  orderType    OrderType   @default(COUNTER)
  status       OrderStatus @default(OPEN)
  saleId       String?
  customerName String?
  phone        String?
  channel      String      @default("POS") // POS | QR | ONLINE | WAITER
  kotPending   Boolean     @default(false)
  kotVersion   Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt @default(now())

  shop  Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  table RestaurantTable? @relation(fields: [tableId], references: [id])
  waiter User?           @relation(fields: [waiterId], references: [id])
  items OrderItem[]
  logs  OrderLog[]

  @@index([shopId, status])
  @@index([shopId, kotPending])
}

model OrderLog {
  id        String         @id @default(uuid())
  shopId    String
  orderId   String
  userId    String?
  action    OrderLogAction
  detail    String?
  createdAt DateTime       @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([shopId, createdAt])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  productId   String
  name        String
  variationId String?
  quantity    Decimal    @db.Decimal(18, 3)
  unitPrice   Decimal    @db.Decimal(18, 2)
  note        String?
  prepStatus  PrepStatus @default(PENDING)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ── Purchasing (M2) ───────────────────────────────────────────────────
model Purchase {
  id            String        @id @default(uuid())
  shopId        String
  billNo        String
  vendorId      String?
  subtotal      Decimal       @db.Decimal(18, 2)
  discount      Decimal       @default(0) @db.Decimal(18, 2)
  tax           Decimal       @default(0) @db.Decimal(18, 2)
  total         Decimal       @db.Decimal(18, 2)
  paymentMethod PaymentMethod @default(CREDIT)
  note          String?
  journalId     String?
  createdAt     DateTime      @default(now())

  shop   Shop           @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vendor Vendor?        @relation(fields: [vendorId], references: [id])
  items  PurchaseItem[]

  @@unique([shopId, billNo])
  @@index([shopId, createdAt])
}

model PurchaseItem {
  id         String  @id @default(uuid())
  purchaseId String
  productId  String
  name       String
  quantity   Decimal @db.Decimal(18, 3)
  unitCost   Decimal @db.Decimal(18, 2)
  lineTotal  Decimal @db.Decimal(18, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
}

// Settlements: paying a vendor (AP↓) or receiving from a customer (AR↓).
model PartyPayment {
  id         String           @id @default(uuid())
  shopId     String
  type       PartyPaymentType
  vendorId   String?
  customerId String?
  method     PaymentMethod    @default(CASH)
  amount     Decimal          @db.Decimal(18, 2)
  note       String?
  journalId  String?
  createdAt  DateTime         @default(now())

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  vendor   Vendor?   @relation(fields: [vendorId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([shopId, createdAt])
}
